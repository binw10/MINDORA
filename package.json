{
  "name": "mindora-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "preflight": "bash scripts/preflight.sh",
    "healthcheck": "bash scripts/healthcheck.sh",
    "backup:production": "bash scripts/backup-production.sh",
    "deploy:local": "bash scripts/deploy-local.sh",
    "audit:production": "bash scripts/audit-production.sh"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
